generator client {
  provider               = "prisma-client"
  previewFeatures        = ["postgresqlExtensions"]
  engineType             = "client"
  runtime                = "nodejs"
  moduleFormat           = "esm"
  generatedFileExtension = "ts"
  importFileExtension    = "ts"
  output                 = "./generated"
}

datasource db {
  provider   = "postgresql"
  extensions = [postgis]
}

model User {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  name  String?
  phone String  @unique

  role Role @default(CLIENT)

  properties Property[] @relation("HostProperties")
  bookings   Booking[]  @relation("ClientBookings")
  Review     Review[]
}

model Property {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  name        String
  slug        String  @unique
  description String?

  city    String?
  address String?

  latitude  Float?
  longitude Float?

  location Unsupported("geometry(Point,4326)")?

  status PropertyStatus @default(DRAFT)

  policy CancellationPolicy @default(FLEXIBLE)

  contactPhone String?
  contactEmail String?
  website      String?

  checkInFrom String?
  checkOutTo  String?

  metaTitle       String?
  metaDescription String?

  categoryId String
  category   PropertyCategory @relation(fields: [categoryId], references: [id])

  hostId String
  host   User   @relation("HostProperties", fields: [hostId], references: [id], onDelete: Cascade)

  units   Unit[]
  images  Image[]
  reviews Review[]

  @@index([slug])
  @@index([city])
  @@index([status])
}

model PropertyCategory {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  name String
  slug String @unique

  properties Property[]
}

model Unit {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  name        String
  description String?

  price    Int
  capacity Int

  bookingType BookingType @default(DAILY)

  status UnitStatus @default(ACTIVE)

  categoryId String
  category   UnitCategory @relation(fields: [categoryId], references: [id])

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  features Feature[]

  images Image[]

  bookings Booking[]

  @@index([propertyId])
  @@index([status])
}

model UnitCategory {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  name String
  slug String @unique

  units Unit[]
}

model Feature {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  name String
  slug String @unique

  units Unit[]
}

model Booking {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  checkIn  DateTime
  checkOut DateTime

  status BookingStatus @default(HOLD)

  totalPrice       Int
  prepaymentAmount Int?

  paymentMethod PaymentMethod @default(ONLINE)

  comment String?

  userId String
  user   User   @relation("ClientBookings", fields: [userId], references: [id])

  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id])

  transaction Transaction?

  @@index([userId])
  @@index([unitId])
  @@index([status])
  @@index([checkIn, checkOut])
}

model Review {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")

  rating  Int
  comment String?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([userId])
}

model Transaction {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")

  amount Int

  providerId String?
  status     TransactionStatus

  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model Image {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  url String

  sortOrder Int @default(0)

  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  unitId String?
  unit   Unit?   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([unitId])
}

enum Role {
  CLIENT
  HOST
  ADMIN
}

enum PropertyStatus {
  DRAFT
  PENDING_MODERATION
  ACTIVE
  REJECTED
  BLOCKED
}

enum UnitStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum CancellationPolicy {
  FLEXIBLE
  STRICT
}

enum BookingType {
  DAILY
  HOURLY
}

enum BookingStatus {
  HOLD
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentMethod {
  ONLINE
  CASH
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}
